{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle owned by the user (Bike, Onewheel, Ebike, etc.)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the vehicle" },
        "type": { "type": "string", "enum": ["bike", "onewheel", "ebike", "other"], "description": "Type of vehicle" },
        "totalMileage": { "type": "number", "description": "Lifetime odometer reading in miles" },
        "tripMileage": { "type": "number", "description": "Current trip meter reading in miles" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "userId"]
    },
    "Ride": {
      "title": "Ride",
      "description": "A single recorded ride session",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string", "description": "ID of the vehicle used" },
        "userId": { "type": "string", "description": "UID of the rider" },
        "distance": { "type": "number", "description": "Distance traveled in this ride" },
        "path": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" },
              "timestamp": { "type": "number" }
            }
          }
        },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["vehicleId", "userId", "distance", "startTime"]
    },
    "Trail": {
      "title": "Trail",
      "description": "A saved reusable path or trail",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the trail" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "distance": { "type": "number" },
        "path": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "userId", "path"]
    }
  },
  "firestore": {
    "vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "User vehicles and their odometers"
    },
    "rides/{rideId}": {
      "schema": "Ride",
      "description": "Recorded ride history and paths"
    },
    "trails/{trailId}": {
      "schema": "Trail",
      "description": "Saved reusable trails"
    }
  }
}
