rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Vehicle Rules
    match /vehicles/{vehicleId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isOwner(incoming().userId)
        && isValidVehicle(incoming())
        && isValidId(vehicleId);
        
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isOwner(incoming().userId)
        && isValidVehicle(incoming())
        // Total mileage can only increase (odometer)
        && incoming().totalMileage >= existing().totalMileage
        // Odometer is static in sense it can't be set to 0 or decreased
        // Trip meter can be resetted
        && (
          // Action: Log Ride mileage
          (incoming().diff(existing()).affectedKeys().hasOnly(['totalMileage', 'tripMileage'])) ||
          // Action: Reset Trip Meter
          (incoming().diff(existing()).affectedKeys().hasOnly(['tripMileage']) && incoming().tripMileage == 0) ||
          // Action: Rename/Edit basic info
          (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type']))
        );
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['name', 'type', 'totalMileage', 'tripMileage', 'userId'])
        && data.name is string && data.name.size() > 0 && data.name.size() < 100
        && data.type in ['bike', 'onewheel', 'ebike', 'hiker', 'other']
        && data.totalMileage is number && data.totalMileage >= 0
        && data.tripMileage is number && data.tripMileage >= 0
        && data.userId == request.auth.uid;
    }

    // Ride Rules
    match /rides/{rideId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isOwner(incoming().userId)
        && isValidRide(incoming())
        && isValidId(rideId);
        
      allow update: if false; // Rides are immutable records
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    function isValidRide(data) {
      return data.keys().hasAll(['vehicleId', 'userId', 'distance', 'startTime', 'path'])
        && data.vehicleId is string
        && data.userId == request.auth.uid
        && data.distance is number && data.distance >= 0
        && data.startTime is timestamp
        && data.path is list && data.path.size() <= 5000; // Limit path points for safety
    }

    // Trail Rules
    match /trails/{trailId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isOwner(incoming().userId)
        && isValidTrail(incoming())
        && isValidId(trailId);
        
      allow update: if isSignedIn() 
        && isOwner(existing().userId)
        && isOwner(incoming().userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['name']);
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    function isValidTrail(data) {
      return data.keys().hasAll(['name', 'userId', 'path', 'distance'])
        && data.name is string && data.name.size() > 0
        && data.userId == request.auth.uid
        && data.path is list && data.path.size() > 0
        && data.distance is number;
    }
  }
}
